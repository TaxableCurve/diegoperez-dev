---
interface Props {
  lang: 'es' | 'en';
  currentPath: string;
}

const { lang, currentPath } = Astro.props;

const isEn = lang === 'en';

const nav = isEn
  ? [
      { href: '/en/', label: 'Home' },
      { href: '/en/projects/', label: 'Projects' },
      { href: '/en/about/', label: 'About' },
      { href: '/en/contact/', label: 'Contact' },
    ]
  : [
      { href: '/', label: 'Inicio' },
      { href: '/proyectos/', label: 'Proyectos' },
      { href: '/sobre-mi/', label: 'Sobre mí' },
      { href: '/contacto/', label: 'Contacto' },
    ];

const routeMap: Record<string, string> = {
  '/': '/en/',
  '/proyectos/': '/en/projects/',
  '/sobre-mi/': '/en/about/',
  '/contacto/': '/en/contact/',
  '/en/': '/',
  '/en/projects/': '/proyectos/',
  '/en/about/': '/sobre-mi/',
  '/en/contact/': '/contacto/',
};

const slugPath = currentPath.match(/^\/proyectos\/(.+)\/$/) ;
const enSlugPath = currentPath.match(/^\/en\/projects\/(.+)\/$/);

let toggleHref: string;
if (slugPath) {
  toggleHref = `/en/projects/${slugPath[1]}/`;
} else if (enSlugPath) {
  toggleHref = `/proyectos/${enSlugPath[1]}/`;
} else {
  toggleHref = routeMap[currentPath] ?? (isEn ? '/' : '/en/');
}

const langToggle = { href: toggleHref, label: isEn ? 'ES' : 'EN' };
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-gray-100">
  <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href={isEn ? '/en/' : '/'} class="font-semibold text-gray-900 hover:text-indigo-600 transition-colors">
      Diego Pérez
    </a>

    <!-- Desktop nav -->
    <nav class="hidden sm:flex items-center gap-1">
      {nav.map(({ href, label }) => (
        <a
          href={href}
          class="px-3 py-1.5 text-sm text-gray-600 hover:text-gray-900 rounded-md hover:bg-gray-50 transition-colors"
        >
          {label}
        </a>
      ))}
      <a
        href={langToggle.href}
        class="ml-3 px-3 py-1.5 text-sm font-medium text-indigo-600 border border-indigo-200 rounded-md hover:bg-indigo-50 transition-colors"
      >
        {langToggle.label}
      </a>
    </nav>

    <!-- Mobile: lang toggle + hamburger -->
    <div class="flex sm:hidden items-center gap-2">
      <a
        href={langToggle.href}
        class="px-3 py-1.5 text-sm font-medium text-indigo-600 border border-indigo-200 rounded-md hover:bg-indigo-50 transition-colors"
      >
        {langToggle.label}
      </a>
      <button
        id="menu-btn"
        aria-label={isEn ? 'Open menu' : 'Abrir menú'}
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="p-2 rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors"
      >
        <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden sm:hidden border-t border-gray-100 bg-white">
    <nav class="max-w-5xl mx-auto px-6 py-3 flex flex-col gap-1">
      {nav.map(({ href, label }) => (
        <a
          href={href}
          class="px-3 py-2 text-sm text-gray-600 hover:text-gray-900 rounded-md hover:bg-gray-50 transition-colors"
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>

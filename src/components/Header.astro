---
interface Props {
  lang: 'es' | 'en';
  currentPath: string;
}

const { lang, currentPath } = Astro.props;

const isEn = lang === 'en';

const nav = isEn
  ? [
      { href: '/en/', label: 'Home' },
      { href: '/en/projects/', label: 'Projects' },
      { href: '/en/about/', label: 'About' },
      { href: '/en/contact/', label: 'Contact' },
    ]
  : [
      { href: '/', label: 'Inicio' },
      { href: '/proyectos/', label: 'Proyectos' },
      { href: '/sobre-mi/', label: 'Sobre mí' },
      { href: '/contacto/', label: 'Contacto' },
    ];

const routeMap: Record<string, string> = {
  '/': '/en/',
  '/proyectos/': '/en/projects/',
  '/sobre-mi/': '/en/about/',
  '/contacto/': '/en/contact/',
  '/en/': '/',
  '/en/projects/': '/proyectos/',
  '/en/about/': '/sobre-mi/',
  '/en/contact/': '/contacto/',
};

const slugPath   = currentPath.match(/^\/proyectos\/(.+)\/$/);
const enSlugPath = currentPath.match(/^\/en\/projects\/(.+)\/$/);

let toggleHref: string;
if (slugPath)        toggleHref = `/en/projects/${slugPath[1]}/`;
else if (enSlugPath) toggleHref = `/proyectos/${enSlugPath[1]}/`;
else                 toggleHref = routeMap[currentPath] ?? (isEn ? '/' : '/en/');

const langToggle = { href: toggleHref, label: isEn ? 'ES' : 'EN' };

function isActive(href: string) {
  if (href === '/' || href === '/en/') return currentPath === href;
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-canvas/90 backdrop-blur-md border-b border-edge">
  <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a
      href={isEn ? '/en/' : '/'}
      class="mono text-sm font-medium text-ink hover:text-glow transition-colors tracking-tight"
    >
      Diego<span class="text-glow">.</span>dev
    </a>

    <!-- Desktop nav -->
    <nav class="hidden sm:flex items-center gap-1">
      {nav.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'px-3 py-1.5 text-sm rounded-md transition-colors',
            isActive(href)
              ? 'text-ink bg-surface2'
              : 'text-dim hover:text-ink hover:bg-surface',
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href={langToggle.href}
        class="ml-3 mono px-3 py-1.5 text-xs font-medium text-glow border border-glow-dim rounded-md hover:bg-surface transition-colors"
      >
        {langToggle.label}
      </a>
    </nav>

    <!-- Mobile: lang toggle + hamburger -->
    <div class="flex sm:hidden items-center gap-2">
      <a
        href={langToggle.href}
        class="mono px-3 py-1.5 text-xs font-medium text-glow border border-glow-dim rounded-md hover:bg-surface transition-colors"
      >
        {langToggle.label}
      </a>
      <button
        id="menu-btn"
        aria-label={isEn ? 'Open menu' : 'Abrir menú'}
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="p-2 rounded-md text-dim hover:text-ink hover:bg-surface transition-colors"
      >
        <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden sm:hidden border-t border-edge bg-surface">
    <nav class="max-w-5xl mx-auto px-6 py-3 flex flex-col gap-1">
      {nav.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'px-3 py-2.5 text-sm rounded-md transition-colors',
            isActive(href)
              ? 'text-ink bg-surface2'
              : 'text-dim hover:text-ink hover:bg-surface2',
          ]}
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn      = document.getElementById('menu-btn');
  const menu     = document.getElementById('mobile-menu');
  const iconOpen  = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>

---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '@/i18n';
import Hero from '@/components/Hero.astro';
import StatGrid from '@/components/StatGrid.astro';
import ProjectCard from '@/components/ProjectCard.astro';

const t = useTranslations('en');

const projects = await getCollection('projects', ({ data }) => data.featured && !data.draft);
projects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Base
  title="Diego Fernando Pérez C. — Full-Stack Developer"
  description="Portfolio of Diego Fernando Pérez C., full-stack developer with experience in frontend, backend and databases."
  lang="en"
>
  <Hero {...t.hero} />
  <StatGrid stats={t.stats} />

  <!-- Who I am -->
  <section class="max-w-5xl mx-auto px-6 py-14 border-t border-edge reveal">
    <p class="mono text-xs text-glow mb-3">{t.home.about.label}</p>
    <h2 class="text-2xl font-bold text-ink mb-5">{t.home.about.heading}</h2>
    <p class="text-dim max-w-2xl leading-relaxed">
      I enjoy the frontend and live in the backend. What I like most is when a project that seemed
      straightforward turns into a real challenge — that moment when you have to research, adapt,
      and come out knowing something you didn't before. In 6 years that's happened more times
      than I can count, and it's the reason I write Go today having started in JavaScript.
    </p>
  </section>

  <!-- Featured projects -->
  <section class="max-w-5xl mx-auto px-6 py-14 border-t border-edge">
    <div class="flex items-end justify-between mb-8 reveal">
      <div>
        <p class="mono text-xs text-glow mb-3">{t.home.projects.label}</p>
        <h2 class="text-2xl font-bold text-ink">{t.home.projects.heading}</h2>
      </div>
      <a href={t.hero.projectsHref} class="mono text-xs text-dim hover:text-glow transition-colors">
        {t.home.projects.viewAll}
      </a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {projects.map((p, i) => (
        <ProjectCard
          title={p.data.title}
          summary={p.data.summary}
          role={p.data.role}
          year={p.data.year}
          stack={p.data.stack.slice(0, 3)}
          href={`/en/projects/${p.id}/`}
          index={i}
        />
      ))}
    </div>
  </section>

  <!-- Stack -->
  <section class="max-w-5xl mx-auto px-6 py-14 border-t border-edge reveal">
    <p class="mono text-xs text-glow mb-3">{t.home.stack.label}</p>
    <h2 class="text-2xl font-bold text-ink mb-10">{t.home.stack.heading}</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {Object.entries(t.stack).map(([area, techs]) => (
        <div>
          <h3 class="mono text-xs text-glow uppercase tracking-widest mb-4">{area}</h3>
          <ul class="space-y-2">
            {techs.map((tech) => (
              <li class="flex items-center gap-2 text-sm text-dim">
                <span class="w-1 h-1 rounded-full bg-glow-dim shrink-0"></span>
                {tech}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="max-w-5xl mx-auto px-6 py-14 border-t border-edge reveal">
    <p class="mono text-xs text-glow mb-3">{t.home.contact.label}</p>
    <h2 class="text-2xl font-bold text-ink mb-4">{t.home.contact.heading}</h2>
    <p class="text-dim mb-8 max-w-lg leading-relaxed">{t.home.contact.description}</p>
    <a href={t.hero.contactHref} class="px-5 py-2.5 bg-glow text-canvas font-semibold rounded-lg hover:brightness-110 transition-all text-sm inline-block">
      {t.home.contact.cta}
    </a>
  </section>
</Base>

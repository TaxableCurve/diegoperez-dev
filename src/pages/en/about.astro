---
import Base from '@/layouts/Base.astro';

const experience = [
  {
    role: 'Senior Back-end Developer',
    company: 'Dropi',
    period: 'April 2025 — present',
    description: 'Design and maintenance of high-performance back-end services. Serverless architectures with AWS Lambdas in Go. SOLID principles and DB version control with Liquibase.',
    stack: ['Go', 'Laravel', 'AWS Lambdas', 'Docker', 'Liquibase'],
  },
  {
    role: 'Software Engineer',
    company: 'Alexandra Lozano Immigration Law',
    period: 'April 2024 — March 2025',
    description: 'Development of responsive web applications, server logic with NestJS and SQL Server database management.',
    stack: ['Nuxt 3', 'Vue 3', 'NestJS', 'TypeScript', 'SQL Server'],
  },
  {
    role: 'Software Development Engineer',
    company: 'DreamCode Software',
    period: 'September 2021 — April 2024',
    description: 'Full-stack development with Angular (Microfrontends) and Spring Boot (Microservices). Database design and API management with AWS API Gateway.',
    stack: ['Angular', 'Spring Boot', 'PostgreSQL', 'DynamoDB', 'AWS'],
  },
  {
    role: 'R&D Software Engineer',
    company: 'Axede S.A.S.',
    period: 'February 2021 — September 2021',
    description: 'Technology research and development in Python, C++ and JavaScript. SQLite and MongoDB database management.',
    stack: ['Python', 'C++', 'JavaScript', 'SQLite', 'MongoDB'],
  },
  {
    role: 'Software Development Engineer',
    company: 'QW Health',
    period: 'November 2019 — February 2021',
    description: 'Full-stack development with the MEAN stack. Project lead and responsible for product deployment and updates.',
    stack: ['MongoDB', 'Express', 'Angular', 'Node.js'],
  },
];
---

<Base
  title="About — Diego Fernando Pérez"
  description="Full-stack developer with experience in frontend, backend and databases."
  lang="en"
>
  <div class="max-w-5xl mx-auto px-6 pt-16 pb-24">
    <div class="max-w-2xl mb-16">
      <h1 class="text-4xl font-bold text-gray-900 mb-6">About me</h1>
      <p class="text-lg text-gray-600 leading-relaxed mb-4">
        I'm Diego Fernando Pérez Carvajal, a Systems Engineer from Universidad Santiago de Cali
        with 6+ years building production software.
      </p>
      <p class="text-gray-600 leading-relaxed mb-4">
        I started as a full-stack developer with the MEAN stack, moved through Angular with Spring Boot microservices,
        integrated legal systems with NestJS, and today I work as a Senior Back-end Developer in Go
        with serverless architectures on AWS. That path wasn't planned — it was the natural result of every
        new project putting me in front of something I didn't know how to do yet.
      </p>
      <p class="text-gray-600 leading-relaxed">
        The same thing happened with my thesis: what started as an academic project turned into a real
        engineering challenge that ended up published as an international paper. That pattern keeps repeating:
        the projects that seem simple are the ones that have taught me the most.
      </p>
    </div>

    <section class="mb-16">
      <h2 class="text-xl font-bold text-gray-900 mb-8">Experience</h2>
      <div class="space-y-8">
        {experience.map((e) => (
          <div class="flex gap-6">
            <div class="w-px bg-gray-100 shrink-0 mt-1.5 ml-1" />
            <div>
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-1">
                <h3 class="font-semibold text-gray-900">{e.role}</h3>
                <span class="text-sm text-gray-400">{e.company}</span>
              </div>
              <p class="text-xs text-indigo-600 font-medium mb-2">{e.period}</p>
              <p class="text-sm text-gray-600 leading-relaxed mb-3">{e.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {e.stack.map((t) => (
                  <span class="text-xs text-gray-500 bg-gray-50 border border-gray-100 px-2 py-0.5 rounded">{t}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-16">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Education</h2>
      <div class="flex gap-6">
        <div class="w-px bg-gray-100 shrink-0 mt-1.5 ml-1" />
        <div>
          <h3 class="font-semibold text-gray-900">Systems Engineering</h3>
          <p class="text-sm text-gray-400 mb-2">Universidad Santiago de Cali · 2016 — 2022</p>
          <p class="text-sm text-gray-600">
            Thesis: mobile app for indoor campus navigation using Google Maps and static routes.
            Published as an academic paper: <em>Development and Impact of a Mobile Application that Allows Users to Track Their Location on an Educational Institution Campus</em>.
          </p>
        </div>
      </div>
    </section>

    <div class="flex flex-wrap gap-3">
      <a href="/en/projects/" class="px-5 py-2.5 bg-indigo-600 text-white rounded-lg font-medium hover:bg-indigo-700 transition-colors">
        View projects
      </a>
      <a href="/en/contact/" class="px-5 py-2.5 border border-gray-200 text-gray-700 rounded-lg font-medium hover:bg-gray-50 transition-colors">
        Get in touch
      </a>
    </div>
  </div>
</Base>

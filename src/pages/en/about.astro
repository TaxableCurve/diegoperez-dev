---
import Base from '@/layouts/Base.astro';

const experience = [
  {
    role: 'CMS Integration Developer',
    company: 'Technology sector company',
    period: '2024 — present',
    description: 'Building the module that connects the CMS with the company\'s main application. Backend in Golang.',
    stack: ['Golang', 'REST APIs'],
  },
  {
    role: 'Full-stack Developer',
    company: 'Legal sector client',
    period: '2023 — 2024',
    description: 'Mobile-first web application to manage documents and organize steps for court cases.',
    stack: ['Angular', 'Node.js', 'PostgreSQL'],
  },
  {
    role: 'Full-stack Developer',
    company: 'Agroindustrial sector client',
    period: '2023',
    description: 'Platform to automate the indemnification process for collective agricultural insurance policies.',
    stack: ['Angular', 'Spring Boot', 'PostgreSQL'],
  },
  {
    role: 'Full-stack Developer',
    company: 'Industrial sector client',
    period: '2022 — 2023',
    description: 'Real-time metrics dashboard for industrial machine monitoring via Firebase.',
    stack: ['Angular', 'Node.js', 'Firebase'],
  },
];
---

<Base
  title="About — Diego Fernando Pérez"
  description="Full-stack developer with experience in frontend, backend and databases."
  lang="en"
>
  <div class="max-w-5xl mx-auto px-6 pt-16 pb-24">
    <div class="max-w-2xl mb-16">
      <h1 class="text-4xl font-bold text-gray-900 mb-6">About me</h1>
      <p class="text-lg text-gray-600 leading-relaxed mb-4">
        I'm Diego Fernando Pérez, a full-stack developer with experience across frontend, backend and databases.
        I've worked on projects ranging from mobile apps to enterprise process automation,
        system integrations and real-time dashboards.
      </p>
      <p class="text-gray-600 leading-relaxed">
        My rotating profile is intentional: I prefer to understand the full system before making technical decisions.
        I work primarily with Angular on the frontend, Node.js and Golang on the backend,
        and PostgreSQL as my main database.
      </p>
    </div>

    <section class="mb-16">
      <h2 class="text-xl font-bold text-gray-900 mb-8">Experience</h2>
      <div class="space-y-8">
        {experience.map((e) => (
          <div class="flex gap-6">
            <div class="w-px bg-gray-100 shrink-0 mt-1.5 ml-1" />
            <div>
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-1">
                <h3 class="font-semibold text-gray-900">{e.role}</h3>
                <span class="text-sm text-gray-400">{e.company}</span>
              </div>
              <p class="text-xs text-indigo-600 font-medium mb-2">{e.period}</p>
              <p class="text-sm text-gray-600 leading-relaxed mb-3">{e.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {e.stack.map((t) => (
                  <span class="text-xs text-gray-500 bg-gray-50 border border-gray-100 px-2 py-0.5 rounded">{t}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-16">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Education</h2>
      <div class="flex gap-6">
        <div class="w-px bg-gray-100 shrink-0 mt-1.5 ml-1" />
        <div>
          <h3 class="font-semibold text-gray-900">Systems / Computer Science Engineering</h3>
          <p class="text-sm text-gray-400 mb-2">University · 2024</p>
          <p class="text-sm text-gray-600">
            Thesis: mobile app for indoor campus navigation using Google Maps and static routes.
          </p>
        </div>
      </div>
    </section>

    <div class="flex flex-wrap gap-3">
      <a href="/en/projects/" class="px-5 py-2.5 bg-indigo-600 text-white rounded-lg font-medium hover:bg-indigo-700 transition-colors">
        View projects
      </a>
      <a href="/en/contact/" class="px-5 py-2.5 border border-gray-200 text-gray-700 rounded-lg font-medium hover:bg-gray-50 transition-colors">
        Get in touch
      </a>
    </div>
  </div>
</Base>

---
import Base from '@/layouts/Base.astro';
import { useTranslations } from '@/i18n';
import StatGrid from '@/components/StatGrid.astro';

const t = useTranslations('en');

const experience = [
  {
    role: 'Senior Back-end Developer',
    company: 'Dropi',
    period: 'April 2025 — present',
    description: 'Development and maintenance of back-end services in Go and Laravel. BFF with NestJS, PostgreSQL database. Involved in integrations with external platforms (Shopify, Tienda Nube) and occasional full-stack work in Angular and React as needed.',
    stack: ['Go', 'Laravel', 'NestJS', 'PostgreSQL', 'Angular', 'React', 'AWS'],
  },
  {
    role: 'Software Engineer',
    company: 'Alexandra Lozano Immigration Law',
    period: 'April 2024 — March 2025',
    description: 'Development of responsive web applications, server logic with NestJS and SQL Server database management.',
    stack: ['Nuxt 3', 'Vue 3', 'NestJS', 'TypeScript', 'SQL Server'],
  },
  {
    role: 'Software Development Engineer',
    company: 'DreamCode Software',
    period: 'September 2021 — April 2024',
    description: 'Full-stack development with Angular (Microfrontends) and Spring Boot (Microservices). Database design and API management with AWS API Gateway.',
    stack: ['Angular', 'Spring Boot', 'PostgreSQL', 'DynamoDB', 'AWS'],
  },
  {
    role: 'R&D Software Engineer',
    company: 'Axede S.A.S.',
    period: 'February 2021 — September 2021',
    description: 'Technology research and development in Python, C++ and JavaScript. SQLite and MongoDB database management.',
    stack: ['Python', 'C++', 'JavaScript', 'SQLite', 'MongoDB'],
  },
  {
    role: 'Software Development Engineer',
    company: 'QW Health',
    period: 'November 2019 — February 2021',
    description: 'Full-stack development with the MEAN stack. Project lead and responsible for product deployment and updates.',
    stack: ['MongoDB', 'Express', 'Angular', 'Node.js'],
  },
];
---

<Base
  title="About — Diego Fernando Pérez C."
  description="Full-stack developer with experience in frontend, backend and databases."
  lang="en"
>

  <!-- Header -->
  <section class="relative overflow-hidden border-b border-edge">
    <div
      class="pointer-events-none absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle, #1e2538 1px, transparent 1px); background-size: 28px 28px;"
    ></div>
    <div
      class="pointer-events-none absolute -top-32 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full opacity-10"
      style="background: radial-gradient(ellipse, #22d3ee 0%, transparent 65%);"
    ></div>

    <div class="relative max-w-5xl mx-auto px-6 pt-16 pb-14">
      <p class="mono text-xs text-glow mb-4">{t.aboutPage.label}</p>
      <h1 class="text-3xl sm:text-5xl font-bold text-ink mb-6 leading-tight">
        {t.aboutPage.heading}
      </h1>
      <p class="text-base text-dim leading-relaxed max-w-xl">
        Systems Engineer with 6+ years building complete products —
        Angular interfaces, NestJS and Go services, and databases that don't surprise you in production.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <StatGrid stats={t.stats} />

  <div class="max-w-5xl mx-auto px-6 pb-24">

    <!-- Bio -->
    <section class="max-w-2xl py-14 border-b border-edge reveal">
      <p class="mono text-xs text-glow mb-6">// Background</p>
      <div class="space-y-4 text-dim leading-relaxed">
        <p>
          I started with the MEAN stack, moved through Angular microfrontends with Spring Boot APIs,
          integrated legal systems with NestJS, and today I build Go services.
          Frontend has always kept me engaged — there's something satisfying about seeing the result
          immediately — but backend is where I spend most of my time and feel most at home.
        </p>
        <p>
          That path wasn't planned. Every new project put me in front of something I didn't know
          how to do, and that forced me to learn. The same happened with my thesis: it started as
          an academic requirement and ended up published as an international paper.
        </p>
        <p>
          That pattern keeps repeating: the projects that seem simple are the ones that have
          taught me the most.
        </p>
      </div>
    </section>

    <!-- Experience -->
    <section class="py-14 border-b border-edge">
      <p class="mono text-xs text-glow mb-3">{t.aboutPage.experience.label}</p>
      <h2 class="text-xl font-bold text-ink mb-10">{t.aboutPage.experience.heading}</h2>
      <div class="relative">
        <div class="absolute left-[7px] top-2 bottom-2 w-px bg-edge"></div>
        {experience.map((e) => (
          <div class="relative flex gap-6 pb-10 last:pb-0 reveal">
            <div class="mt-1 shrink-0 z-10">
              <div class="w-3.5 h-3.5 rounded-full border-2 border-glow bg-canvas"></div>
            </div>
            <div>
              <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1 mb-1">
                <h3 class="font-semibold text-ink">{e.role}</h3>
                <span class="text-dim">·</span>
                <span class="text-sm text-glow font-medium">{e.company}</span>
              </div>
              <p class="mono text-xs text-glow mb-3">{e.period}</p>
              <p class="text-sm text-dim leading-relaxed mb-3">{e.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {e.stack.map((tech) => (
                  <span class="mono text-xs text-dim bg-surface border border-edge px-2 py-0.5 rounded">{tech}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Education -->
    <section class="py-14 border-b border-edge reveal">
      <p class="mono text-xs text-glow mb-3">{t.aboutPage.education.label}</p>
      <h2 class="text-xl font-bold text-ink mb-8">{t.aboutPage.education.heading}</h2>
      <div class="relative flex gap-6">
        <div class="absolute left-[7px] top-2 bottom-2 w-px bg-edge"></div>
        <div class="mt-1 shrink-0 z-10">
          <div class="w-3.5 h-3.5 rounded-full border-2 border-glow bg-canvas"></div>
        </div>
        <div>
          <h3 class="font-semibold text-ink">Systems Engineering</h3>
          <p class="mono text-xs text-glow mb-3">Universidad Santiago de Cali · 2016 — 2022</p>
          <p class="text-sm text-dim leading-relaxed mb-3">
            Thesis: mobile app for indoor campus navigation using Google Maps and static routes.
            Over 5,000 downloads across Android and iOS.
          </p>
          <a
            href="https://online-journals.org/index.php/i-jim/article/view/42905"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 mono text-xs text-glow hover:underline"
          >
            <span>↗</span>
            <span>Published paper: <em class="not-italic">Development and Impact of a Mobile Application that Allows Users to Track Their Location on an Educational Institution Campus</em></span>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="pt-14 reveal">
      <p class="text-sm text-dim mb-4">Want to work together or just learn more?</p>
      <div class="flex flex-wrap gap-3">
        <a href="/en/projects/" class="px-5 py-2.5 bg-glow text-canvas font-semibold rounded-lg hover:brightness-110 transition-all text-sm">
          {t.aboutPage.ctaProjects}
        </a>
        <a href="/en/contact/" class="px-5 py-2.5 border border-edge text-dim rounded-lg font-medium hover:border-glow-dim hover:text-ink transition-all text-sm">
          {t.aboutPage.ctaContact}
        </a>
      </div>
    </div>

  </div>
</Base>

---
import Base from '@/layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, summary, role, stack, client, year, demoUrl, repoUrl } = project.data;
---

<Base title={`${title} — Diego Fernando Pérez`} description={summary} lang="en">

  <!-- Project header -->
  <section class="relative overflow-hidden border-b border-edge">
    <div
      class="pointer-events-none absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle, #1e2538 1px, transparent 1px); background-size: 28px 28px;"
    ></div>
    <div
      class="pointer-events-none absolute -top-32 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full opacity-10"
      style="background: radial-gradient(ellipse, #22d3ee 0%, transparent 65%);"
    ></div>

    <div class="relative max-w-4xl mx-auto px-6 pt-12 pb-14">
      <a href="/en/projects/" class="mono text-xs text-dim hover:text-glow transition-colors mb-8 inline-block">
        ← Projects
      </a>

      <div class="flex flex-wrap items-center gap-2 mb-5">
        <span class="mono text-xs text-glow bg-glow/10 px-2 py-0.5 rounded">{role}</span>
        <span class="mono text-xs text-dim">{year}</span>
        <span class="mono text-xs text-dim">·</span>
        <span class="mono text-xs text-dim">{client}</span>
      </div>

      <h1 class="text-3xl sm:text-5xl font-bold text-ink mb-5 leading-tight max-w-2xl">
        {title}
      </h1>
      <p class="text-base text-dim leading-relaxed max-w-xl">{summary}</p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-6 pb-24">

    <!-- Meta grid -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-px bg-edge rounded-xl overflow-hidden my-10">
      <div class="bg-surface px-5 py-4">
        <p class="mono text-xs text-dim mb-1">Role</p>
        <p class="text-sm font-medium text-ink">{role}</p>
      </div>
      <div class="bg-surface px-5 py-4">
        <p class="mono text-xs text-dim mb-1">Year</p>
        <p class="text-sm font-medium text-ink">{year}</p>
      </div>
      <div class="bg-surface px-5 py-4 col-span-2">
        <p class="mono text-xs text-dim mb-1">Client</p>
        <p class="text-sm font-medium text-ink">{client}</p>
      </div>
    </div>

    <!-- Stack + links -->
    <div class="flex flex-wrap items-center justify-between gap-4 mb-12 pb-10 border-b border-edge">
      <div class="flex flex-wrap gap-2">
        {stack.map((t) => (
          <span class="mono text-xs text-dim bg-surface border border-edge px-3 py-1 rounded-md">{t}</span>
        ))}
      </div>
      <div class="flex gap-3">
        {demoUrl && (
          <a href={demoUrl} target="_blank" rel="noopener"
            class="mono text-xs text-glow border border-glow-dim px-3 py-1.5 rounded-md hover:bg-glow/10 transition-colors">
            Demo →
          </a>
        )}
        {repoUrl && (
          <a href={repoUrl} target="_blank" rel="noopener"
            class="mono text-xs text-dim border border-edge px-3 py-1.5 rounded-md hover:border-glow-dim hover:text-glow transition-colors">
            Repo →
          </a>
        )}
      </div>
    </div>

    <!-- Content -->
    <div class="prose max-w-none
      prose-invert
      prose-headings:font-bold prose-headings:text-ink
      prose-h2:text-lg prose-h2:mt-12 prose-h2:mb-4
      prose-h2:border-l-2 prose-h2:border-glow prose-h2:pl-3
      prose-p:text-dim prose-p:leading-relaxed
      prose-li:text-dim prose-ul:space-y-1
      prose-strong:text-ink
      prose-a:text-glow prose-a:no-underline hover:prose-a:underline
      prose-code:text-glow prose-code:bg-surface prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-xs prose-code:before:content-none prose-code:after:content-none
      prose-hr:border-edge">
      <Content />
    </div>

    <!-- CTA final -->
    <div class="mt-16 pt-10 border-t border-edge flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <div>
        <p class="mono text-xs text-glow mb-1">// Interested in this kind of work?</p>
        <p class="text-dim text-sm">I can apply the same approach to your project.</p>
      </div>
      <div class="flex gap-3 shrink-0">
        <a href="/en/contact/"
          class="px-4 py-2 bg-glow text-canvas font-semibold rounded-lg hover:brightness-110 transition-all text-sm">
          Let's talk
        </a>
        <a href="/en/projects/"
          class="px-4 py-2 border border-edge text-dim rounded-lg hover:border-glow-dim hover:text-ink transition-all text-sm">
          More projects
        </a>
      </div>
    </div>

  </div>
</Base>

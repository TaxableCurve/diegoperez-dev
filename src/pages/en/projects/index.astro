---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects', ({ data }) => !data.draft);
projects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Base
  title="Projects — Diego Fernando Pérez"
  description="Real case studies: problem, technical decisions and outcome."
  lang="en"
>
  <div class="max-w-5xl mx-auto px-6 pt-16 pb-24">
    <div class="max-w-2xl mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Projects</h1>
      <p class="text-gray-600">
        Real case studies: what needed to be solved, what I decided and why, and what the outcome was.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {projects.map((p) => (
        <a
          href={`/en/projects/${p.id}/`}
          class="group flex flex-col p-6 border border-gray-100 rounded-xl hover:border-indigo-200 hover:shadow-sm transition-all"
        >
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xs font-medium text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded">
              {p.data.role}
            </span>
            <span class="text-xs text-gray-400">{p.data.year}</span>
            <span class="text-xs text-gray-400 ml-auto">{p.data.client}</span>
          </div>
          <h2 class="font-semibold text-gray-900 mb-2 group-hover:text-indigo-600 transition-colors">
            {p.data.title}
          </h2>
          <p class="text-sm text-gray-500 leading-relaxed flex-1">{p.data.summary}</p>
          <div class="flex flex-wrap gap-1.5 mt-4">
            {p.data.stack.map((t) => (
              <span class="text-xs text-gray-500 bg-gray-50 border border-gray-100 px-2 py-0.5 rounded">{t}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>

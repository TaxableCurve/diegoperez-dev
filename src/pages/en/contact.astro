---
import Base from '@/layouts/Base.astro';
import { useTranslations } from '@/i18n';

const t = useTranslations('en');
---

<Base
  title="Contact — Diego Fernando Pérez"
  description="Get in touch with Diego Fernando Pérez."
  lang="en"
>

  <!-- Header -->
  <section class="relative overflow-hidden border-b border-edge">
    <div
      class="pointer-events-none absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle, #1e2538 1px, transparent 1px); background-size: 28px 28px;"
    ></div>
    <div
      class="pointer-events-none absolute -top-32 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full opacity-10"
      style="background: radial-gradient(ellipse, #22d3ee 0%, transparent 65%);"
    ></div>

    <div class="relative max-w-5xl mx-auto px-6 pt-16 pb-14">
      <p class="mono text-xs text-glow mb-4">{t.contactPage.label}</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-ink mb-5 leading-tight">
        {t.contactPage.heading}
      </h1>
      <p class="text-base text-dim leading-relaxed max-w-xl">
        {t.contactPage.description}
      </p>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-6 pt-12 pb-24">
    <div class="max-w-xl space-y-3 reveal">

      <a href="mailto:diego.fdo.perez7@hotmail.com"
        class="flex items-center gap-4 p-5 bg-surface border border-edge rounded-xl hover:border-glow-dim transition-all duration-200 group">
        <div class="w-10 h-10 bg-glow/10 border border-glow-dim rounded-lg flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-glow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </div>
        <div>
          <p class="font-medium text-ink group-hover:text-glow transition-colors text-sm">Email</p>
          <p class="mono text-xs text-dim mt-0.5">diego.fdo.perez7@hotmail.com</p>
        </div>
        <span class="ml-auto text-dim group-hover:text-glow transition-colors">→</span>
      </a>

      <a href="https://github.com/TaxableCurve" target="_blank" rel="noopener"
        class="flex items-center gap-4 p-5 bg-surface border border-edge rounded-xl hover:border-glow-dim transition-all duration-200 group">
        <div class="w-10 h-10 bg-surface2 border border-edge rounded-lg flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-dim group-hover:text-glow transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
        </div>
        <div>
          <p class="font-medium text-ink group-hover:text-glow transition-colors text-sm">GitHub</p>
          <p class="mono text-xs text-dim mt-0.5">github.com/TaxableCurve</p>
        </div>
        <span class="ml-auto text-dim group-hover:text-glow transition-colors">→</span>
      </a>

      <a href="https://linkedin.com/in/diego-fernando-p-42b010149" target="_blank" rel="noopener"
        class="flex items-center gap-4 p-5 bg-surface border border-edge rounded-xl hover:border-glow-dim transition-all duration-200 group">
        <div class="w-10 h-10 bg-surface2 border border-edge rounded-lg flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-dim group-hover:text-glow transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </div>
        <div>
          <p class="font-medium text-ink group-hover:text-glow transition-colors text-sm">LinkedIn</p>
          <p class="mono text-xs text-dim mt-0.5">linkedin.com/in/diego-fernando-p-42b010149</p>
        </div>
        <span class="ml-auto text-dim group-hover:text-glow transition-colors">→</span>
      </a>

    </div>
  </div>
</Base>

---
import Base from '@/layouts/Base.astro';
import { useTranslations } from '@/i18n';
import StatGrid from '@/components/StatGrid.astro';

const t = useTranslations('es');

const experiencia = [
  {
    rol: 'Senior Back-end Developer',
    empresa: 'Dropi',
    periodo: 'Abril 2025 — presente',
    descripcion: 'Desarrollo y mantenimiento de servicios back-end en Go y Laravel. BFF con NestJS, base de datos PostgreSQL. Participación en integraciones con plataformas externas (Shopify, Tienda Nube) y desarrollo full-stack puntual en Angular y React según el proyecto.',
    stack: ['Go', 'Laravel', 'NestJS', 'PostgreSQL', 'Angular', 'React', 'AWS'],
  },
  {
    rol: 'Software Engineer',
    empresa: 'Alexandra Lozano Immigration Law',
    periodo: 'Abril 2024 — Marzo 2025',
    descripcion: 'Desarrollo de aplicaciones web responsive, lógica de servidor con NestJS y administración de bases de datos SQL Server.',
    stack: ['Nuxt 3', 'Vue 3', 'NestJS', 'TypeScript', 'SQL Server'],
  },
  {
    rol: 'Ingeniero de Desarrollo de Software',
    empresa: 'DreamCode Software',
    periodo: 'Septiembre 2021 — Abril 2024',
    descripcion: 'Desarrollo full-stack con Angular (Microfrontends) y Spring Boot (Microservicios). Diseño de bases de datos y gestión de APIs con AWS API Gateway.',
    stack: ['Angular', 'Spring Boot', 'PostgreSQL', 'DynamoDB', 'AWS'],
  },
  {
    rol: 'Ingeniero de Desarrollo e Investigación',
    empresa: 'Axede S.A.S.',
    periodo: 'Febrero 2021 — Septiembre 2021',
    descripcion: 'Investigación de tecnologías y desarrollo en Python, C++ y JavaScript. Manejo de bases de datos SQLite y MongoDB.',
    stack: ['Python', 'C++', 'JavaScript', 'SQLite', 'MongoDB'],
  },
  {
    rol: 'Ingeniero de Desarrollo de Software',
    empresa: 'QW Health',
    periodo: 'Noviembre 2019 — Febrero 2021',
    descripcion: 'Desarrollo full-stack con el stack MEAN. Líder de proyecto y responsable del despliegue y actualización de productos.',
    stack: ['MongoDB', 'Express', 'Angular', 'Node.js'],
  },
];
---

<Base
  title="Sobre mí — Diego Fernando Pérez"
  description="Desarrollador full-stack con experiencia en frontend, backend y bases de datos."
>

  <!-- Header -->
  <section class="relative overflow-hidden border-b border-edge">
    <div
      class="pointer-events-none absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle, #1e2538 1px, transparent 1px); background-size: 28px 28px;"
    ></div>
    <div
      class="pointer-events-none absolute -top-32 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full opacity-10"
      style="background: radial-gradient(ellipse, #22d3ee 0%, transparent 65%);"
    ></div>

    <div class="relative max-w-5xl mx-auto px-6 pt-16 pb-14">
      <p class="mono text-xs text-glow mb-4">{t.aboutPage.label}</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-ink mb-6 leading-tight">
        {t.aboutPage.heading}
      </h1>
      <p class="text-base text-dim leading-relaxed max-w-xl">
        Ingeniero de Sistemas con más de 6 años construyendo productos completos —
        interfaces en Angular, servicios en NestJS y Go, y bases de datos que no dan sorpresas en producción.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <StatGrid stats={t.stats} />

  <div class="max-w-5xl mx-auto px-6 pb-24">

    <!-- Bio -->
    <section class="max-w-2xl py-14 border-b border-edge reveal">
      <p class="mono text-xs text-glow mb-6">// Trayectoria</p>
      <div class="space-y-4 text-dim leading-relaxed">
        <p>
          Empecé con el stack MEAN, pasé por microfrontends en Angular con APIs en Spring Boot,
          integré sistemas legales con NestJS y hoy desarrollo servicios en Go.
          El frontend siempre me ha entretenido — hay algo satisfactorio en ver el resultado
          inmediato — pero el backend es donde paso la mayor parte del tiempo y donde más cómodo me siento.
        </p>
        <p>
          Esa trayectoria no fue planeada. Cada proyecto nuevo me puso frente a algo que no sabía
          hacer, y eso me obligó a aprender. Lo mismo pasó con la tesis: empezó como requisito
          académico y terminó publicada como artículo internacional.
        </p>
        <p>
          Ese patrón se repite: los proyectos que parecen simples son los que más me han enseñado.
        </p>
      </div>
    </section>

    <!-- Experiencia -->
    <section class="py-14 border-b border-edge">
      <p class="mono text-xs text-glow mb-3">{t.aboutPage.experience.label}</p>
      <h2 class="text-xl font-bold text-ink mb-10">{t.aboutPage.experience.heading}</h2>
      <div class="relative">
        <div class="absolute left-[7px] top-2 bottom-2 w-px bg-edge"></div>
        {experiencia.map((e) => (
          <div class="relative flex gap-6 pb-10 last:pb-0 reveal">
            <div class="mt-1 shrink-0 z-10">
              <div class="w-3.5 h-3.5 rounded-full border-2 border-glow bg-canvas"></div>
            </div>
            <div>
              <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1 mb-1">
                <h3 class="font-semibold text-ink">{e.rol}</h3>
                <span class="text-dim">·</span>
                <span class="text-sm text-glow font-medium">{e.empresa}</span>
              </div>
              <p class="mono text-xs text-glow mb-3">{e.periodo}</p>
              <p class="text-sm text-dim leading-relaxed mb-3">{e.descripcion}</p>
              <div class="flex flex-wrap gap-1.5">
                {e.stack.map((tech) => (
                  <span class="mono text-xs text-dim bg-surface border border-edge px-2 py-0.5 rounded">{tech}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Formación -->
    <section class="py-14 border-b border-edge reveal">
      <p class="mono text-xs text-glow mb-3">{t.aboutPage.education.label}</p>
      <h2 class="text-xl font-bold text-ink mb-8">{t.aboutPage.education.heading}</h2>
      <div class="relative flex gap-6">
        <div class="absolute left-[7px] top-2 bottom-2 w-px bg-edge"></div>
        <div class="mt-1 shrink-0 z-10">
          <div class="w-3.5 h-3.5 rounded-full border-2 border-glow bg-canvas"></div>
        </div>
        <div>
          <h3 class="font-semibold text-ink">Ingeniería de Sistemas</h3>
          <p class="mono text-xs text-glow mb-3">Universidad Santiago de Cali · 2016 — 2022</p>
          <p class="text-sm text-dim leading-relaxed mb-3">
            Tesis: aplicación móvil de navegación indoor para campus universitario con Google Maps
            y rutas estáticas. Más de 5.000 descargas entre Android e iOS.
          </p>
          <a
            href="https://online-journals.org/index.php/i-jim/article/view/42905"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 mono text-xs text-glow hover:underline"
          >
            <span>↗</span>
            <span>Artículo publicado: <em class="not-italic">Development and Impact of a Mobile Application that Allows Users to Track Their Location on an Educational Institution Campus</em></span>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="pt-14 reveal">
      <p class="text-sm text-dim mb-4">¿Quieres trabajar juntos o simplemente conocer más?</p>
      <div class="flex flex-wrap gap-3">
        <a href="/proyectos/" class="px-5 py-2.5 bg-glow text-canvas font-semibold rounded-lg hover:brightness-110 transition-all text-sm">
          {t.aboutPage.ctaProjects}
        </a>
        <a href="/contacto/" class="px-5 py-2.5 border border-edge text-dim rounded-lg font-medium hover:border-glow-dim hover:text-ink transition-all text-sm">
          {t.aboutPage.ctaContact}
        </a>
      </div>
    </div>

  </div>
</Base>

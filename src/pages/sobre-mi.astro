---
import Base from '@/layouts/Base.astro';

const experiencia = [
  {
    rol: 'Senior Back-end Developer',
    empresa: 'Dropi',
    periodo: 'Abril 2025 — presente',
    descripcion: 'Diseño y mantenimiento de servicios back-end de alto rendimiento. Arquitecturas serverless con AWS Lambdas en Go. Principios SOLID y control de versiones de BD con Liquibase.',
    stack: ['Go', 'Laravel', 'AWS Lambdas', 'Docker', 'Liquibase'],
  },
  {
    rol: 'Software Engineer',
    empresa: 'Alexandra Lozano Immigration Law',
    periodo: 'Abril 2024 — Marzo 2025',
    descripcion: 'Desarrollo de aplicaciones web responsive, lógica de servidor con NestJS y administración de bases de datos SQL Server.',
    stack: ['Nuxt 3', 'Vue 3', 'NestJS', 'TypeScript', 'SQL Server'],
  },
  {
    rol: 'Ingeniero de Desarrollo de Software',
    empresa: 'DreamCode Software',
    periodo: 'Septiembre 2021 — Abril 2024',
    descripcion: 'Desarrollo full-stack con Angular (Microfrontends) y Spring Boot (Microservicios). Diseño de bases de datos y gestión de APIs con AWS API Gateway.',
    stack: ['Angular', 'Spring Boot', 'PostgreSQL', 'DynamoDB', 'AWS'],
  },
  {
    rol: 'Ingeniero de Desarrollo e Investigación',
    empresa: 'Axede S.A.S.',
    periodo: 'Febrero 2021 — Septiembre 2021',
    descripcion: 'Investigación de tecnologías y desarrollo en Python, C++ y JavaScript. Manejo de bases de datos SQLite y MongoDB.',
    stack: ['Python', 'C++', 'JavaScript', 'SQLite', 'MongoDB'],
  },
  {
    rol: 'Ingeniero de Desarrollo de Software',
    empresa: 'QW Health',
    periodo: 'Noviembre 2019 — Febrero 2021',
    descripcion: 'Desarrollo full-stack con el stack MEAN. Líder de proyecto y responsable del despliegue y actualización de productos.',
    stack: ['MongoDB', 'Express', 'Angular', 'Node.js'],
  },
];
---

<Base
  title="Sobre mí — Diego Fernando Pérez"
  description="Desarrollador full-stack con experiencia en frontend, backend y bases de datos."
>
  <div class="max-w-5xl mx-auto px-6 pt-16 pb-24">
    <!-- Encabezado -->
    <div class="max-w-2xl mb-16">
      <h1 class="text-4xl font-bold text-gray-900 mb-6">Sobre mí</h1>
      <p class="text-lg text-gray-600 leading-relaxed mb-4">
        Soy Diego Fernando Pérez Carvajal, Ingeniero de Sistemas de la Universidad Santiago de Cali
        con más de 4 años de experiencia en desarrollo de software.
      </p>
      <p class="text-gray-600 leading-relaxed">
        He trabajado en proyectos que van desde aplicaciones móviles hasta automatización de procesos empresariales,
        integraciones de sistemas y arquitecturas serverless. Mi perfil rotativo entre frontend, backend y bases de datos
        me permite entender el sistema completo antes de tomar decisiones técnicas.
      </p>
    </div>

    <!-- Experiencia -->
    <section class="mb-16">
      <h2 class="text-xl font-bold text-gray-900 mb-8">Experiencia</h2>
      <div class="space-y-8">
        {experiencia.map((e) => (
          <div class="flex gap-6">
            <div class="w-px bg-gray-100 shrink-0 mt-1.5 ml-1" />
            <div>
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-1">
                <h3 class="font-semibold text-gray-900">{e.rol}</h3>
                <span class="text-sm text-gray-400">{e.empresa}</span>
              </div>
              <p class="text-xs text-indigo-600 font-medium mb-2">{e.periodo}</p>
              <p class="text-sm text-gray-600 leading-relaxed mb-3">{e.descripcion}</p>
              <div class="flex flex-wrap gap-1.5">
                {e.stack.map((t) => (
                  <span class="text-xs text-gray-500 bg-gray-50 border border-gray-100 px-2 py-0.5 rounded">{t}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Formación -->
    <section class="mb-16">
      <h2 class="text-xl font-bold text-gray-900 mb-6">Formación</h2>
      <div class="flex gap-6">
        <div class="w-px bg-gray-100 shrink-0 mt-1.5 ml-1" />
        <div>
          <h3 class="font-semibold text-gray-900">Ingeniería de Sistemas</h3>
          <p class="text-sm text-gray-400 mb-2">Universidad Santiago de Cali · 2016 — 2022</p>
          <p class="text-sm text-gray-600">
            Tesis: aplicación móvil de navegación indoor para campus universitario con Google Maps y rutas estáticas.
            Publicada como artículo académico: <em>Development and Impact of a Mobile Application that Allows Users to Track Their Location on an Educational Institution Campus</em>.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="flex flex-wrap gap-3">
      <a href="/proyectos/" class="px-5 py-2.5 bg-indigo-600 text-white rounded-lg font-medium hover:bg-indigo-700 transition-colors">
        Ver proyectos
      </a>
      <a href="/contacto/" class="px-5 py-2.5 border border-gray-200 text-gray-700 rounded-lg font-medium hover:bg-gray-50 transition-colors">
        Contactarme
      </a>
    </div>
  </div>
</Base>

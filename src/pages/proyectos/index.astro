---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '@/i18n';
import ProjectCard from '@/components/ProjectCard.astro';

const t = useTranslations('es');

const proyectos = await getCollection('proyectos', ({ data }) => !data.draft);
proyectos.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Base
  title="Proyectos — Diego Fernando Pérez C."
  description="Casos de estudio reales: problema, decisiones técnicas y resultado."
>

  <!-- Header -->
  <section class="relative overflow-hidden border-b border-edge">
    <div
      class="pointer-events-none absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle, #1e2538 1px, transparent 1px); background-size: 28px 28px;"
    ></div>
    <div
      class="pointer-events-none absolute -top-32 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full opacity-10"
      style="background: radial-gradient(ellipse, #22d3ee 0%, transparent 65%);"
    ></div>

    <div class="relative max-w-5xl mx-auto px-6 pt-16 pb-14">
      <p class="mono text-xs text-glow mb-4">{t.projectsPage.label}</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-ink mb-5 leading-tight">
        {t.projectsPage.heading}
      </h1>
      <p class="text-base text-dim leading-relaxed max-w-xl">
        {t.projectsPage.description}
      </p>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-6 pt-12 pb-24">
    <div class="grid sm:grid-cols-2 gap-4">
      {proyectos.map((p, i) => (
        <ProjectCard
          title={p.data.title}
          summary={p.data.summary}
          role={p.data.role}
          year={p.data.year}
          stack={p.data.stack}
          href={`/proyectos/${p.id}/`}
          index={i}
          client={p.data.client}
          showClient
        />
      ))}
    </div>
  </div>
</Base>
